<h1>{{title}}</h1>

{{#if error}}
  <p class="form-error">{{error}}</p>
{{/if}}


<form method="post" action="/recipes/{{recipe.id}}">
  <div>
    <label for="title">Recipe Title</label>
    <input type="text" id="title" name="title" value="{{recipe.title}}" required>
  </div>

  <div>
    <label for="description">Description</label>
    <textarea id="description" name="description" required>{{recipe.description}}</textarea>
  </div>

  <div>
    <label for="ingredients">Ingredients</label>
    <textarea id="ingredients" name="ingredients" required>{{recipe.ingredients}}</textarea>
  </div>

  <div>
    <label for="instructions">Instructions</label>
    <textarea id="instructions" name="instructions" required>{{recipe.instructions}}</textarea>
  </div>

  <div>
    <label for="prep_time">Prep Time (minutes)</label>
    <input type="number" id="prep_time" name="prep_time" value="{{recipe.prep_time}}" min="1" step="1" required>
  </div>

  <div>
    <label for="cook_time">Cook Time (minutes)</label>
    <input type="number" id="cook_time" name="cook_time" value="{{recipe.cook_time}}" min="1" step="1" required>
  </div>

  <div>
    <label for="servings">Servings</label>
    <input type="number" id="servings" name="servings" value="{{recipe.servings}}" min="1" step="1" required>
  </div>

  <div class="form-actions">
    <button type="submit">Update Recipe</button>
    <a href="/recipes/{{recipe.id}}" class="button-link button-secondary">Cancel</a>
  </div>
</form>
