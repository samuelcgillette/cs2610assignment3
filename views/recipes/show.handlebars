<h1>{{recipe.title}}</h1>

<p>{{recipe.description}}</p>

<h3>Ingredients</h3>
<p>{{recipe.ingredients}}</p>

<h3>Instructions</h3>
<p>{{recipe.instructions}}</p>

<div class="recipe-details">
  <p><strong>Creator:</strong> <a href="/user/{{recipe.user_id}}">View Creator</a></p>
  <p><strong>Prep Time:</strong> {{recipe.prep_time}} minutes</p>
  <p><strong>Cook Time:</strong> {{recipe.cook_time}} minutes</p>
  <p><strong>Servings:</strong> {{recipe.servings}}</p>
</div>


<div class="recipe-actions">
  {{#if isOwner}}
    <a href="/recipes/{{recipe.id}}/edit">Edit</a>
    <form method="post" action="/recipes/{{recipe.id}}/delete" style="display:inline;">
      <button type="submit">Delete</button>
    </form>
  {{/if}}


  {{#if authenticated}}
    <form method="post" action="/recipes/{{recipe.id}}/rate" style="display:inline;">
        <input type="number" name="rating" min="1" max="5" required>
        <button type="submit">Rate</button>
    </form>
    <form method="post" action="/recipes/{{recipe.id}}/favorite" style="display:inline;">
        <button type="submit">Favorite</button>
    </form>
  {{/if}}
</div>
