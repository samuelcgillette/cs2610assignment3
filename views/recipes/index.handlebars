<h1>{{title}}</h1>
<form method="get" action="/recipes" class="search-form">
  <input type="text" name="search" placeholder="Search recipes...">
    <button type="submit">Search</button>
</form>
<div class="recipes-container">
  {{#each recipes}}
    <div class="recipe-card">
      <h2><a href="/recipes/{{id}}">{{title}}</a></h2>
      <p><strong>Creator:</strong> <a href="/user/{{user_id}}">View Creator</a></p>
      <p>{{description}}</p>
      <p><strong>Prep Time:</strong> {{prep_time}} minutes</p>
      <p><strong>Cook Time:</strong> {{cook_time}} minutes</p>
      <p><strong>Servings:</strong> {{servings}}</p>
    </div>
  {{/each}}
</div>
