<div class="home-header">
    <div class="home-hero">
        <img src="/cook.jpg" alt="Cooking" class="home-hero-image">
        <div class="home-hero-overlay">welcome to recpie social</div>
    </div>
    <p class="home-subtitle">latest recpies</p>
    <hr class="home-divider">
</div>

<div class="recipes-container">
    {{#each recipes}}
        <div class="recipe-card">
            <h2><a href="/recipes/{{id}}">{{title}}</a></h2>
            <p>by: {{username}}</p>
            <p>{{description}}</p>
            <p><strong>Prep Time:</strong> {{prep_time}} minutes</p>
            <p><strong>Cook Time:</strong> {{cook_time}} minutes</p>
            <p><strong>Servings:</strong> {{servings}}</p>
        </div>
    {{/each}}
</div>

<section class="home-about">
    <h3>About Recipe Social</h3>
    <p>Recipe Social is a place to discover, share, and save recipes with other home cooks. You can browse recent recipes, create your own, edit or update them over time, rate dishes you try, and favorite recipes you want to revisit later.</p>
</section>