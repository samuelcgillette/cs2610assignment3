<h1>{{user.username}}</h1>
<p><strong>Recipes Created:</strong> {{numRecipes}}</p>
<p><strong>Member Since:</strong> {{accountCreatedAt}}</p>

<div class="recipes-container">
  {{#each recipes}}
    <div class="recipe-card">
      <h2><a href="/recipes/{{id}}">{{title}}</a></h2>
      <p>by: {{username}}</p>
      <p>{{description}}</p>
      <p><strong>Prep Time:</strong> {{prep_time}} minutes</p>
      <p><strong>Cook Time:</strong> {{cook_time}} minutes</p>
      <p><strong>Servings:</strong> {{servings}}</p>
    </div>
  {{else}}
    <p>This user has not posted any recipes yet.</p>
  {{/each}}
</div>
